  async function post(body: any) {
    const res = await fetch("/api/state", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    setRooms(data.rooms || []);
    setPlayers(data.players || []);
    setMatches(data.matches || []);
    setJackpot(data.jackpot || null);

    return data;
  }

  async function createRoom() {
    const data = await post({
      type: "room",
      wager: bet,
      creator: me,
      demo: !connected
    });
    if (data.activeRoom?.id) setActiveRoomId(data.activeRoom.id);
  }

  async function joinRoom(roomId: string) {
    setActiveRoomId(roomId);
    await post({ type: "join", roomId, joiner: me });
  }

  async function quickMatch() {
    const waitingRoom = rooms.find((r) => r.status === "waiting" && r.creator !== me);

    if (waitingRoom) {
      await joinRoom(waitingRoom.id);
      return;
    }

    await createRoom();
  }

  async function choose(choice: Side) {
    if (!activeRoom) return;
    const player = activeRoom.creator === me ? "creator" : "joiner";
    await post({ type: "choose", roomId: activeRoom.id, player, choice });
  }

  
  async function depositToEscrow(room: any) {
    if (!connected || !publicKey) {
      alert("Connect your wallet first.");
      return false;
    }

    const mintAddress = process.env.NEXT_PUBLIC_TOKEN_MINT || "";
    if (!mintAddress || mintAddress.includes("PASTE_")) {
      alert("$COIN token mint is not set yet. This unlocks at Pump.fun launch.");
      return false;
    }

    try {
      const escrowRes = await fetch("/api/escrow/deposit-address", { cache: "no-store" });
      const escrow = await escrowRes.json();

      if (!escrow.ok || !escrow.escrowWallet) {
        alert("Escrow wallet is not ready.");
        return false;
      }

      const mint = new PublicKey(mintAddress);
      const escrowWallet = new PublicKey(escrow.escrowWallet);

      const mintInfo = await getMint(connection, mint);
      const fromAta = await getAssociatedTokenAddress(mint, publicKey);
      const toAta = await getAssociatedTokenAddress(mint, escrowWallet);

      const tx = new Transaction();

      try {
        await getAccount(connection, toAta);
      } catch {
        tx.add(
          createAssociatedTokenAccountInstruction(
            publicKey,
            toAta,
            escrowWallet,
            mint
          )
        );
      }

      const rawAmount = BigInt(Math.floor(Number(room.wager || 0) * 10 ** mintInfo.decimals));

      tx.add(
        createTransferCheckedInstruction(
          fromAta,
          mint,
          toAta,
          publicKey,
          rawAmount,
          mintInfo.decimals
        )
      );

      const sig = await sendTransaction(tx, connection);
      await connection.confirmTransaction(sig, "confirmed");

      const verify = await fetch("/api/escrow/verify-deposit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          signature: sig,
          wallet: me,
          roomId: room.id,
          amount: room.wager
        })
      });

      const verified = await verify.json();
      if (!verified.ok) {
        alert(verified.error || "Deposit verification failed.");
        return false;
      }

      await post({
        type: "deposit-confirm",
        roomId: room.id,
        wallet: me,
        signature: sig
      });

      await loadState();
      alert("Bet deposited to escrow.");
      return true;
    } catch (e: any) {
      alert(e.message || "Deposit failed.");
      return false;
    }
  }

async function flipRoom() {
    if (activeRoom && !(
      (activeRoom.creator === me && activeRoom.creatorDeposited) ||
      (activeRoom.joiner === me && activeRoom.joinerDeposited)
    )) {
      const ok = await depositToEscrow(activeRoom);
      if (!ok) return;
    }

    if (activeRoom && !activeRoom.escrowReady) {
      alert("Waiting for both players to deposit to escrow.");
      return;
    }

    if (!activeRoom || flipping || countdown) return;

    setMatchPhase("LOCKING MATCH");
    setCountdown("");

    setTimeout(() => setMatchPhase("BETS LOCKED"), 600);
    setTimeout(() => setCountdown("3"), 1100);
    setTimeout(() => setCountdown("2"), 1800);
    setTimeout(() => setCountdown("1"), 2500);
    setTimeout(() => {
      setCountdown("FLIP!");
      setFlipping(true);
      setMatchPhase("COIN LAUNCHED");
    }, 3200);

    setTimeout(() => {
      setMatchPhase("SLOW MOTION");
    }, 4700);

    setTimeout(async () => {
      await post({ type: "flip", roomId: activeRoom.id });
      setFlipping(false);
      setCountdown("");
      setMatchPhase("COIN LANDED");
    }, 6400);
  }

  async function sendChat(e: React.FormEvent) {
    e.preventDefault();
    if (!chatInput.trim()) return;
    await post({ type: "chat", wallet: me, message: chatInput.trim() });
    setChatInput("");
  }

  function myStats() {
    return getStats(me);
  }

  function getLevelProgress(stats:any) {
    const xp = stats?.xp || 0;
    const level = Math.max(1, Math.floor(xp / 500) + 1);
    const currentLevelXp = (level - 1) * 500;
    const nextLevelXp = level * 500;
    const progress = Math.min(100, Math.round(((xp - currentLevelXp) / 500) * 100));

    return {
      xp,
      level,
      currentLevelXp,
      nextLevelXp,
      progress
    };
  }

  function getStats(name?: string) {
    const p = players.find((x:any) => x.name === name);
    const wins = p?.wins || 0;
    const losses = p?.losses || 0;
    const total = wins + losses;
    return {
      wins,
      losses,
      streak: p?.currentStreak || 0,
      bestStreak: p?.bestStreak || 0,
      totalWon: p?.totalWon || 0,
      xp: p?.xp || 0,
      level: p?.level || Math.max(1, Math.floor((p?.xp || 0) / 500) + 1),
      winRate: total ? Math.round((wins / total) * 100) : 0
    };
  }

  function joinTournament() {
    if (tournamentPlayers.includes(me)) return;
    if (tournamentPlayers.length >= 8) return;
    setTournamentPlayers((old) => [...old, me]);
  }

  function fillTournamentBots() {
    const bots = ["FlipKing", "LuckyLarry", "CoinMaster", "TossTitan", "MoonTosser", "GoldFlip", "SolWhale", "PumpLord"];
    const needed = 8 - tournamentPlayers.length;
    setTournamentPlayers((old) => [...old, ...bots.filter((b) => !old.includes(b)).slice(0, needed)]);
  }

  function runTournament() {
    if (tournamentPlayers.length < 8) {
      alert("Tournament needs 8 players.");
      return;
    }

    let players = [...tournamentPlayers];

    while (players.length > 1) {
      const nextRound:string[] = [];

      for (let i = 0; i < players.length; i += 2) {
        const winner = Math.random() < 0.5 ? players[i] : players[i + 1];
        nextRound.push(winner);
      }

      players = nextRound;
    }

    setTournamentWinner(players[0]);
  }

