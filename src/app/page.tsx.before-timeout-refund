                  </button>

                  <button
                    onClick={() => {
                      setActiveRoomId("");
                      setTab("match");
                    }}
                    className="rounded-2xl border border-white/15 bg-white/5 px-8 py-4 text-xl font-black text-white"
                  >
                    LOBBY
                  </button>
                </div>
              </div>
            )}
          </section>
        )}

        {tab === "leaderboard" && (
          <section className="rounded-[1.4rem] border border-emerald-400/20 bg-black/30 p-6 shadow-[0_0_90px_rgba(16,185,129,0.12)]">
            <div className="mb-6 flex items-center justify-between">
              <div>
                <div className="text-xs font-black tracking-[0.35em] text-emerald-300">
                  GLOBAL RANKINGS
                </div>
                <h2 className="mt-2 text-4xl font-black">LEADERBOARD</h2>
              </div>
              <div className="rounded-2xl bg-emerald-400/10 px-5 py-3 text-sm font-black text-emerald-300">
                {matches.length.toLocaleString()} GAMES
              </div>
            </div>

            {players.length === 0 ? (
              <div className="rounded-xl bg-black/35 p-4 text-zinc-400">No players yet</div>
            ) : (
              [...players]
                .sort((a:any, b:any) => (b.totalWon || 0) - (a.totalWon || 0))
                .map((p:any, i:number) => {
                  const total = (p.wins || 0) + (p.losses || 0);
                  const winRate = total ? Math.round(((p.wins || 0) / total) * 100) : 0;
                  const level = p.level || Math.max(1, Math.floor((p.xp || 0) / 500) + 1);

                  return (
                    <button
                      key={p.name}
                      onClick={() => setSelectedPlayer({
                        name: p.name,
                        stats: {
                          wins: p.wins || 0,
                          losses: p.losses || 0,
                          streak: p.currentStreak || 0,
                          bestStreak: p.bestStreak || 0,
                          totalWon: p.totalWon || 0,
                          xp: p.xp || 0,
                          level,
                          winRate
                        }
                      })}
                      className="mb-3 grid w-full grid-cols-[60px_1fr] gap-4 rounded-2xl border border-white/10 bg-black/35 p-4 text-left transition hover:border-emerald-400/40 hover:bg-emerald-400/10 md:grid-cols-[70px_1fr_120px_120px_160px]"
                    >
                      <div className="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-400 text-xl font-black text-black">
                        #{i + 1}
                      </div>

                      <div>
                        <div className="text-xl font-black">{p.name}</div>
                        <div className="text-sm text-zinc-400">
                          Level {level} • 🔥 Streak {p.currentStreak || 0} • Best {p.bestStreak || 0}
                        </div>
                      </div>

                      <div className="hidden md:block">
                        <div className="text-xs text-zinc-500">WINS</div>
                        <div className="font-black text-emerald-300">{p.wins || 0}</div>
                      </div>

                      <div className="hidden md:block">
                        <div className="text-xs text-zinc-500">WIN RATE</div>
                        <div className="font-black text-yellow-300">{winRate}%</div>
                      </div>

                      <div className="hidden md:block">
                        <div className="text-xs text-zinc-500">TOTAL WON</div>
                        <div className="font-black text-emerald-300">
                          {(p.totalWon || 0).toLocaleString()} {tokenSymbol}
                        </div>
                      </div>
                    </button>
                  );
                })
            )}
          </section>
        )}

        {chatOpen && (
          <>
            <div className="h-64 overflow-y-auto p-4 text-sm">
              {messages.length === 0 ? (
                <div className="flex h-full items-center justify-center text-zinc-500">No messages yet</div>
              ) : (
                messages.map((msg, i) => (
                  <div key={i} className="mb-3 text-zinc-300">{msg}</div>
                ))
              )}
            </div>

            <form onSubmit={sendChat} className="flex gap-2 border-t border-white/10 p-3">
              <input value={chatInput} onChange={(e) => setChatInput(e.target.value)} placeholder="Type message..." className="w-full rounded-xl border border-white/10 bg-black px-3 py-2 text-sm outline-none" />
              <button className="rounded-xl bg-emerald-400 px-4 py-2 text-sm font-black text-black">SEND</button>
            </form>
          </>
        )}
      </div>
    </main>
    </>
  );
}



